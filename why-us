<script>
const _g=document.getElementById('cursor-glow');
document.addEventListener('mousemove',e=>{_g.style.left=e.clientX+'px';_g.style.top=e.clientY+'px';});
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',scrollY>60));
const obs=new IntersectionObserver(es=>es.forEach(e=>e.isIntersecting&&e.target.classList.add('visible')),{threshold:.08});
document.querySelectorAll('.reveal,.reveal-left,.reveal-right').forEach(r=>obs.observe(r));
let cDone=false;
const cObs=new IntersectionObserver(es=>{if(es[0].isIntersecting&&!cDone){cDone=true;document.querySelectorAll('.counter').forEach(el=>{const t=+el.dataset.t,d=1800,s=60,step=t/s;let c=0;const iv=setInterval(()=>{c+=step;if(c>=t){c=t;clearInterval(iv);}el.textContent=Math.round(c);},d/s);});}},{threshold:.5});
cObs.observe(document.getElementById('stats-band'));
function toggleMenu(){const n=document.querySelector('.nav-links');if(n.style.display==='flex'){n.style.display='none';}else{n.style.cssText='display:flex;flex-direction:column;position:fixed;top:68px;left:0;right:0;background:var(--surface);padding:2rem 5vw;gap:1.5rem;z-index:99;border-bottom:1px solid var(--border);';}}
</script>
